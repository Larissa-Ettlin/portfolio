---
import Layout from "@/layouts/layout-principal.astro";
import siteConfig from "@/config/site.json";

import ListProjects from "@/components/list-projects.astro";
const { site, company, contact, experience } = siteConfig;

import { Image } from "astro:assets";
import { Button } from "@/components/ui/button";
import { withBasePath } from "@/lib/utils";

const toInternalLink = (url: string) =>
  withBasePath(url, import.meta.env.BASE_URL);
const hasCompanyLogo = Boolean(company.logo?.trim());
const companyInitial = company.name?.trim().slice(0, 1).toUpperCase() || "L";
const showStatusBlock = company.status?.show !== false && Boolean(company.status?.text?.trim());
const showBookCall =
  contact.bookCall?.enabled !== false &&
  Boolean(contact.bookCall?.text?.trim()) &&
  Boolean(contact.bookCall?.url?.trim());
const showChat =
  contact.chat?.enabled !== false &&
  Boolean(contact.chat?.text?.trim()) &&
  Boolean(contact.chat?.url?.trim());
const browserTitle =
  site.browserTitle?.trim() ||
  site.name?.trim() ||
  `${company.name} | ${company.description}`;
---

<Layout
  title={browserTitle}
  description={company.longDescription || company.description}
  keywords={company.specialties.join(", ")}
  type="profile"
  tags={company.specialties}
>
  <Fragment slot="left-content">
    <div class="flex w-full flex-col gap-6">
      <div class="flex items-center gap-3">
        {
          hasCompanyLogo ? (
            <Image
              src={company.logo}
              alt={company.name}
              width="32"
              height="32"
              class="rounded-full"
              loading="eager"
            />
          ) : (
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-neutral-900 text-xs font-semibold text-white">
              {companyInitial}
            </div>
          )
        }
        {
          showStatusBlock && (
            <div class="flex items-center gap-2">
              <span class="relative flex size-2">
                <span
                  class={`absolute inline-flex h-full w-full animate-ping rounded-full opacity-75 ${company.status.available ? "bg-emerald-400" : "bg-red-400"}`}
                ></span>
                <span
                  class={`relative inline-flex size-2 rounded-full ${company.status.available ? "bg-emerald-500" : "bg-red-500"}`}
                ></span>
              </span>

              <span class="text-xs font-medium text-gray-600">
                {company.status.text}
              </span>
            </div>
          )
        }
      </div>
      <div class="flex flex-col gap-3">
        <h1 class="text-balance font-semibold text-2xl">
          {company.name}
        </h1>
        <h2 class="text-balance font-normal text-2xl">
          {company.description}
        </h2>
        <p class="text-sm text-gray-500">{company.longDescription}</p>
      </div>
      {
        (showBookCall || showChat) && (
          <div class="flex items-center gap-3">
            {
              showBookCall && (
                <a href={toInternalLink(contact.bookCall.url)}>
                  <Button>
                    {contact.bookCall.text}
                  </Button>
                </a>
              )
            }
            {
              showChat && (
                <a
                  href={contact.chat.url.startsWith("/") ? toInternalLink(contact.chat.url) : contact.chat.url}
                  target={contact.chat.url.startsWith("/") ? undefined : "_blank"}
                >
                  <Button variant="outline">
                    {contact.chat.text}
                  </Button>
                </a>
              )
            }
          </div>
        )
      }
      <div class="flex flex-col gap-3 w-full">
        {
          experience.map((exp) => (
            <div class="group relative flex flex-col py-3 px-3 rounded-lg hover:bg-gray-50 transition-all duration-300 ease-in-out cursor-pointer">
              <div class="flex items-center justify-between w-full">
                <h3 class="font-medium text-sm text-gray-900">{exp.company}</h3>
                <span class="text-xs text-gray-400">{exp.year}</span>
              </div>
              <div class="overflow-hidden transition-all duration-300 ease-in-out">
                <div class="max-h-20 lg:max-h-0 lg:group-hover:max-h-20 transition-all duration-300 ease-in-out">
                  <p class="text-xs text-gray-500 pt-2 leading-relaxed">
                    {exp.description}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Fragment>
  <Fragment slot="right-content">
    <ListProjects />
  </Fragment>
</Layout>
